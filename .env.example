# GT Mesh Docker Configuration
# Copy to .env and fill in your values

# Identity (required)
GT_NAME=gt-my-instance
GT_OWNER_NAME=Your Name
GT_OWNER_EMAIL=you@example.com
GT_OWNER_GITHUB=your-github-username

# Join an existing mesh (optional — omit to init a new mesh)
MESH_INVITE_CODE=

# Sync settings
SYNC_INTERVAL=120
AUTO_SYNC_CONFIG=true

# Dolt credentials (optional — will auto-generate if not set)
# Export from: dolt creds ls
DOLT_CREDS_PUB=
DOLT_CREDS_PRIV=
DOLT_CREDS_DIR=
